# ==============================================
# web-insight 环境变量配置
# 复制此文件为 .env 并填入实际值
# ==============================================

# ── LLM 配置 ──────────────────────────────────
LLM_API_KEY=your_zhipu_api_key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL_NAME=GLM-4-Flash-250414
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# ── VLM 配置（视觉模型） ──────────────────────
VLM_API_KEY=your_zhipu_api_key
VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VLM_MODEL_NAME=GLM-4.1V-Thinking-Flash
VLM_TEMPERATURE=0.1
VLM_MAX_TOKENS=2048
VLM_TIMEOUT=30
VLM_MAX_RETRIES=3

# ── Agent 配置 ────────────────────────────────
AGENT_MAX_STEPS=15
AGENT_RECURSION_LIMIT=16
AGENT_MAX_FAILURES=5
AGENT_VLM_FALLBACK=3

# ── 路径配置 ──────────────────────────────────
SCREENSHOT_DIR=data/screenshots
EXPERIENCE_DIR=data/experiences
CHROMA_PERSIST_DIR=data/chroma
LOG_DIR=data/logs

# ── 调试 ──────────────────────────────────────
DEBUG=True
LOG_LEVEL=DEBUG
SAVE_SCREENSHOTS=True